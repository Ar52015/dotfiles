# uwsm auto-start (must be before instant prompt — it execs)
if uwsm check may-start >/dev/null 2>&1; then
	exec uwsm start hyprland.desktop;
fi

# Enable Powerlevel10k instant prompt.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export PATH="$HOME/bin:$HOME/.local/bin:$PATH"

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

zstyle ':omz:update' mode reminder

setopt extendedglob

plugins=(git git-auto-fetch colored-man-pages fzf zsh-autosuggestions zsh-syntax-highlighting)

source $ZSH/oh-my-zsh.sh

bindkey -v
ZLE_RPROMPT_INDENT=0
bindkey '^f' autosuggest-accept

alias ls="lsd"
alias tree="lsd --tree"
alias cat="bat"
alias grep="grep --color=auto"

export EDITOR="nvim"
export VISUAL="nvim"

# fastfetch configs
alias ff="fastfetch"
alias ffd="fastfetch --config ~/.config/fastfetch/detailed.jsonc"
alias ffh="fastfetch --config ~/.config/fastfetch/hardware.jsonc"
alias ffs="fastfetch --config ~/.config/fastfetch/software.jsonc"
alias ffp="fastfetch --config ~/.config/fastfetch/processes.jsonc"
alias ffn="fastfetch --config ~/.config/fastfetch/network.jsonc"
alias ffm="fastfetch --config ~/.config/fastfetch/media.jsonc"

wallust () {
	command wallust "$@"
	kitty @ --to="KITTY_LISTEN_ON" set-colors -a -c ~/.config/kitty/wallust.conf 2>/dev/null || true
}

. "$HOME/.local/bin/env"

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

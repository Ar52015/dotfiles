[[ $- != *i* ]] && return
PROMPT='[%n@%m %~]%# '

# Lines configured by zsh-newuser-install
HISTFILE=~/.histfile
HISTSIZE=10000
SAVEHIST=10000
setopt extendedglob
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
bindkey -e
# End of lines configured by zsh-newuser-install
# The following lines were added by compinstall
zstyle :compinstall filename '/home/aryan/.zshrc'

autoload -Uz compinit
compinit
# End of lines added by compinstall

if uwsm check may-start >/dev/null 2>&1; then
	exec uwsm start hyprland.desktop;
fi

alias ls="lsd"
alias tree="lsd --tree"
alias cat="bat"
alias grep="grep --color=auto"

export EDITOR="nvim"
export VISUAL="nvim"

# fastfetch configs
alias ff="fastfetch"
alias ffd="fastfetch --config ~/.config/fastfetch/detailed.jsonc"
alias ffh="fastfetch --config ~/.config/fastfetch/hardware.jsonc"
alias ffs="fastfetch --config ~/.config/fastfetch/software.jsonc"
alias ffp="fastfetch --config ~/.config/fastfetch/processes.jsonc"
alias ffn="fastfetch --config ~/.config/fastfetch/network.jsonc"
alias ffm="fastfetch --config ~/.config/fastfetch/media.jsonc"

wallust () {
	command wallust "$@"
	kitty @ --to="KITTY_LISTEN_ON" set-colors -a -c ~/.config/kitty/wallust.conf 2>/dev/null || true
}

export PATH="$HOME/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

fastfetch

. "$HOME/.local/bin/env"

source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
